# ==============================================================================
# Aerocode - .gitignore Global (Raiz do Projeto)
# ==============================================================================

# Dependências e Pacotes (Node.js)
# ------------------------------------------------------------------------------
node_modules/
/frontend/node_modules/
/backend/node_modules/
package-lock.json
/frontend/package-lock.json
/backend/package-lock.json
yarn.lock
pnpm-lock.yaml

# Compilação, Builds e Distribuição
# ------------------------------------------------------------------------------
dist/
/frontend/dist/
/backend/dist/
/backend/out/
*.tsbuildinfo

# Variáveis de Ambiente e Segredos (CRÍTICO para segurança)
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
/backend/.env
/frontend/.env

# Prisma ORM (Arquivos locais de Migração temporária)
# ------------------------------------------------------------------------------
/backend/prisma/*.db
/backend/prisma/*.db-journal
/backend/prisma/migrations/**/migration.sql.bak

# Docker e Logs de Processo
# ------------------------------------------------------------------------------
.docker/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Sistema Operacional e IDEs (VS Code, JetBrains, macOS, Windows)
# ------------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvsca*
*.njsproj
*.sln
*.swp
*.DS_Store
Thumbs.db

# Logs de Testes de Carga e Estresse (AV3 - Autocannon / K6)
# ------------------------------------------------------------------------------
*.log
/backend/logs/
/frontend/logs/
stress-test-results/